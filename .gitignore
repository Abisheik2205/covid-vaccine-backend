# ============================================================
# .gitignore — Files NOT to push to GitHub
# CRITICAL: Never push secrets to GitHub!
# ============================================================

# Firebase secret key — NEVER commit this!
src/main/resources/firebase-key.json
firebase-key.json

# Environment variable files — NEVER commit these!
.env
.env.local
.env.production

# Only .env.example is safe to commit (has no real values)

# Maven
target/
*.class

# Eclipse
.classpath
.project
.settings/
bin/

# IntelliJ
.idea/
*.iml

# OS
.DS_Store
Thumbs.db

# Logs
*.log
